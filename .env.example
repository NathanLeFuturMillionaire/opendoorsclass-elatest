# Copy to `.env.local` (local dev) or configure in Vercel Project Settings > Environment Variables.
# Client-exposed (Vite injects at build time)
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# Server-only (SSR + server functions)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# Chariow (paiements)
CHARIOW_API_KEY=""
CHARIOW_PRODUCT_ID=""
CHARIOW_WEBHOOK_SECRET=""

# Moneroo (si utilisé)
MONEROO_SECRET_KEY=""
MONEROO_WEBHOOK_SECRET=""

# Lovable AI Gateway
LOVABLE_API_KEY=""